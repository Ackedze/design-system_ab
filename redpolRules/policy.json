{
  "metadata": {
    "title": "policy",
    "author": "",
    "version": "1.0",
    "last-update": "2026-02-18T00:00:00.000Z"
  },
  "rules": [
    {
      "id": "rp-yo-ctx-001",
      "section": "Орфография",
      "title": "Слово «все»",
      "severity": "mandatory",
      "analysis_scope": "sentence",
      "requires_context": true,
      "rewrite_allowed": true,
      "rule": "Определять, является ли «все» местоимением или наречием. В значении «всё» использовать букву ё.",
      "input_requirements": [
        "Полное предложение"
      ],
      "evaluation_criteria": [
        "Если слово отвечает на вопрос «что именно?» — писать «всё»",
        "Если это форма множественного числа «все клиенты» — не менять"
      ],
      "good_examples": [
        "Это всё?",
        "Не всё работает"
      ],
      "bad_examples": [
        "Это все?",
        "Не все работает"
      ]
    },
    {
      "id": "rp-yo-ctx-002",
      "section": "Орфография",
      "title": "Слова с буквой ё",
      "severity": "mandatory",
      "analysis_scope": "sentence",
      "requires_context": true,
      "rewrite_allowed": true,
      "rule": "Исправляй написание слов, в которых по орфографической норме обязательно используется «ё».",
      "instruction_for_llm": "Меняй «е» на «ё» только в тех словах, где это приводит к нормативному написанию (например: счёт, всё, ещё, перенесён). Не изменяй слова, в которых «е» является правильной буквой (например: кабинет, уведомление, клиент). Если нет уверенности — не исправляй.",
      "input_requirements": [
        "Полное предложение"
      ],
      "evaluation_criteria": [
        "Сохранять регистр",
        "Не изменять другие части слова",
        "Не добавлять новые слова"
      ],
      "good_examples": [
        "Деньги будут зачислены на счёт клиента",
        "рой пчёл",
        "Митинг перенесён на четверг"
      ],
      "bad_examples": [
        "Счет компании",
        "рой пчел",
        "Митинг перенесен на четверг"
      ]
    },
    {
      "id": "rp-term-ctx-001",
      "section": "Терминология",
      "title": "Контекстная замена терминов",
      "severity": "mandatory",
      "analysis_scope": "sentence",
      "requires_context": true,
      "rewrite_allowed": true,
      "rule": "При замене терминов учитывать падеж, число и регистр.",
      "input_requirements": [
        "Полное предложение",
        "Словарь допустимых терминов"
      ],
      "evaluation_criteria": [
        "Сохранять падеж",
        "Сохранять число",
        "Сохранять регистр",
        "Не нарушать грамматику"
      ],
      "good_examples": [
        "Встреча с сотрудником банка",
        "Сотрудник банка ожидает вас"
      ],
      "bad_examples": [
        "Встреча с сотрудник банкаом",
        "сотрудник банка ожидает"
      ]
    },
    {
      "id": "rp-date-ctx-001",
      "section": "Дата и время",
      "title": "Формат даты зависит от сценария",
      "severity": "mandatory",
      "analysis_scope": "component",
      "requires_context": true,
      "rewrite_allowed": true,
      "rule": "Формат даты должен соответствовать сценарию использования (история операций, описание, юридический текст).",
      "input_requirements": [
        "Тип компонента",
        "Полный текст узла"
      ],
      "evaluation_criteria": [
        "В истории операций допустим формат 1.02.22",
        "В описаниях использовать 1 февраля 2025"
      ]
    },
    {
      "id": "rp-dot-ctx-001",
      "section": "Точки",
      "title": "Точка в конце абзаца",
      "severity": "mandatory",
      "analysis_scope": "component",
      "requires_context": true,
      "rewrite_allowed": true,
      "rule": "Определять необходимость точки в зависимости от типа компонента и количества предложений.",
      "input_requirements": [
        "Тип компонента",
        "Текст целиком"
      ],
      "evaluation_criteria": [
        "В кнопках точку не ставим",
        "Если текст состоит из одного предложения в карточке — точку не ставим",
        "В пушах точка обязательна"
      ]
    },
    {
      "id": "rp-capital-ctx-001",
      "section": "Кавычки и названия",
      "title": "Капитализация уникальных названий",
      "severity": "mandatory",
      "analysis_scope": "sentence",
      "requires_context": true,
      "rewrite_allowed": false,
      "rule": "Уникальные названия продуктов, сервисов и услуг писать с заглавной буквы, если иное не предусмотрено глоссарием.",
      "input_requirements": [
        "Глоссарий",
        "Предложение"
      ],
      "evaluation_criteria": [
        "Название из глоссария — с заглавной",
        "Обычные существительные — не менять"
      ]
    },
    {
      "id": "rp-style-ctx-001",
      "section": "Стиль",
      "title": "Простота и понятность формулировок",
      "severity": "advisory",
      "analysis_scope": "sentence",
      "requires_context": true,
      "rewrite_allowed": true,
      "rule": "Формулировки должны быть простыми и понятными пользователю.",
      "evaluation_criteria": [
        "Избегать канцеляризмов",
        "Избегать сложноподчинённых конструкций",
        "Предлагать более короткие варианты"
      ]
    },
    {
      "id": "rp-tone-ctx-001",
      "section": "Tone of Voice",
      "title": "Соответствие tone-of-voice банка",
      "severity": "mandatory",
      "analysis_scope": "page",
      "requires_context": true,
      "rewrite_allowed": true,
      "rule": "Текст должен соответствовать принятому tone-of-voice банка.",
      "input_requirements": [
        "Все тексты страницы",
        "Описание tone-of-voice"
      ],
      "evaluation_criteria": [
        "Доброжелательность",
        "Отсутствие агрессивной лексики",
        "Единый стиль"
      ]
    }
  ]
}