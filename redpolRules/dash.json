  "metadata": {
    "title": "Знаки и неразрывные пробелы",
    "author": "",
    "version": "1.0",
    "last-update": "2026-02-12T10:04:10.440Z"
  },
  "rules": [
    {
      "id": "rp-dash-001",
      "section": "Тире",
      "title": "",
      "severity": "mandatory",
      "rule": "В числовых интервалах ставим среднее тире. И отбиваем неразрывным пробелом",
      "good_examples": [
        "10 000 – 120 000 ₽",
        "2 800 – 10 000 $"
      ],
      "bad_examples": [
        "10000₽—120000₽",
        "10 000 ₽ - 120 000 ₽"
      ]
    },
    {
      "id": "rp-dash-002",
      "section": "Тире",
      "title": "",
      "severity": "mandatory",
      "rule": "В словах с дефисом нужно использовать неразрывный дефис",
      "good_examples": [
        "10 000 – 120 000 ₽",
        "2 800 – 10 000 $"
      ],
      "bad_examples": [
        "10000₽—120000₽",
        "10 000 ₽ - 120 000 ₽"
      ]
    },
    {
      "id": "rp-dash-003",
      "section": "Тире",
      "title": "",
      "severity": "mandatory",
      "rule": "Между длинным длинным тире и предыдущим словом всегда используем неразрывный промел",
      "good_examples": [
        "Кредитная карта Альфа-Банка — это 100 дней свободы от процентов"
      ],
      "bad_examples": [
        "Кредитная карта Альфа-Банка — это 100 дней свободы от процентов"
      ]
    }
  ]
}